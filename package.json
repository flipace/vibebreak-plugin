{
  "name": "vibebreak",
  "version": "0.1.4",
  "description": "Lock your Claude Code sessions every N tokens until you move. Phone counts reps and posts a BeReal-style snap to friends.",
  "author": "flipace <neschkudla@gmail.com>",
  "license": "MIT",
  "homepage": "https://vibebreak.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flipace/vibebreak-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/flipace/vibebreak-plugin/issues"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "fitness",
    "break",
    "posture",
    "streak",
    "bereal",
    "movement"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "vibebreak": "dist/bin/vibebreak.js"
  },
  "files": [
    ".claude-plugin",
    "dist",
    "hooks",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch bin/vibebreak.ts",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "kleur": "4.1.5",
    "qrcode-terminal": "0.12.0",
    "ws": "8.18.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "22.7.6",
    "@types/qrcode-terminal": "0.12.2",
    "@types/ws": "8.5.13",
    "tsup": "8.3.5",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  }
}
